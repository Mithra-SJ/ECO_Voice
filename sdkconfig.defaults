# ESP-SR Configuration
CONFIG_ESP_SR_EN=y
CONFIG_ESP_SR_WN=y
CONFIG_ESP_SR_MN=y

# WakeNet Configuration
CONFIG_ESP_SR_WN_WN9_HILEXIN=y

# MultiNet Configuration
CONFIG_ESP_SR_MN_EN=y
CONFIG_ESP_SR_MN_CN=y

# Audio Processing
CONFIG_ESP_SR_MN_EN=y

